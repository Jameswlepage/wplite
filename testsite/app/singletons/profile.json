{
  "id": "profile",
  "label": "Profile",
  "type": "singleton",
  "storage": "option",
  "fields": {
    "full_name": {
      "type": "text",
      "label": "Full Name"
    },
    "role_line": {
      "type": "text",
      "label": "Role Line"
    },
    "short_bio": {
      "type": "richtext",
      "label": "Short Bio"
    },
    "location": {
      "type": "text",
      "label": "Location"
    },
    "availability": {
      "type": "select",
      "label": "Availability",
      "options": [
        "open",
        "limited",
        "closed"
      ]
    },
    "resume_url": {
      "type": "url",
      "label": "Resume URL"
    },
    "avatar": {
      "type": "image",
      "label": "Avatar"
    }
  }
}
