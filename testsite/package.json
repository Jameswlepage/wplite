{
  "name": "wp-light",
  "private": true,
  "type": "module",
  "bin": {
    "wp-light": "./scripts/wp-light.mjs"
  },
  "scripts": {
    "compile": "node ./scripts/compile.mjs",
    "build:admin": "vite build --config ./admin-app/vite.config.mjs",
    "build": "node ./scripts/wp-light.mjs build",
    "apply": "node ./scripts/wp-light.mjs apply",
    "dev": "node ./scripts/wp-light.mjs dev",
    "pull": "node ./scripts/wp-light.mjs pull",
    "eject": "node ./scripts/wp-light.mjs eject",
    "wp-env:start": "npm run build && npx wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:destroy": "wp-env destroy",
    "seed": "npx wp-env run cli wp eval 'portfolio_light_seed_site();'",
    "rebuild": "npm run build && npm run seed"
  },
  "dependencies": {
    "@wordpress/components": "^32.4.0",
    "@wordpress/dataviews": "^13.1.0",
    "gray-matter": "^4.0.3",
    "marked": "^16.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.4",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@wordpress/env": "^11.2.0",
    "vite": "^7.1.10"
  }
}
