{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "paper", "name": "Paper", "color": "#f4f1e8" },
        { "slug": "surface", "name": "Surface", "color": "#fbfbf8" },
        { "slug": "ink", "name": "Ink", "color": "#111111" },
        { "slug": "charcoal", "name": "Charcoal", "color": "#3f3d39" },
        { "slug": "fog", "name": "Fog", "color": "#d9d3c7" },
        { "slug": "red", "name": "Museum Red", "color": "#c21e1e" }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1420px"
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 6,
        "mediumStep": 1.2,
        "unit": "rem"
      },
      "units": ["px", "rem", "%", "vh", "vw"]
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Museum Sans",
          "slug": "museum-sans"
        },
        {
          "fontFamily": "\"Arial Narrow\", \"Helvetica Neue\", Helvetica, Arial, sans-serif",
          "name": "Museum Condensed",
          "slug": "museum-condensed"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.84rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.4rem", "name": "Large" },
        { "slug": "x-large", "size": "clamp(2.6rem, 5vw, 5.8rem)", "name": "X Large" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--paper)",
      "text": "var(--wp--preset--color--ink)"
    },
    "spacing": {
      "blockGap": "1.25rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--museum-sans)",
      "lineHeight": "1.55"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--museum-condensed)",
          "fontWeight": "700",
          "letterSpacing": "-0.03em",
          "lineHeight": "0.96"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--red)"
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--ink)",
          "text": "var(--wp--preset--color--surface)"
        },
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "0.8rem",
            "right": "1.3rem",
            "bottom": "0.8rem",
            "left": "1.3rem"
          }
        },
        "typography": {
          "fontWeight": "600",
          "letterSpacing": "0.02em",
          "textTransform": "uppercase",
          "fontSize": "0.82rem"
        }
      }
    }
  },
  "customTemplates": [
    { "name": "about", "title": "About" },
    { "name": "contact", "title": "Contact" }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
